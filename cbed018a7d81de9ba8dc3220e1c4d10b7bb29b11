est.el \\\n        -f ert-run-tests-batch-and-exit\n    benchmark-check:\n      glob: \"*.el\"\n      run: >\n        emacs --batch -L . -l ob-gptel-bench.el --eval '\n        (let* ((results (ob-gptel-bench-run))\n               (baseline-file \".benchmark-baseline\")\n               (failed nil))\n          (when (file-exists-p baseline-file)\n            (with-temp-buffer\n              (insert-file-contents baseline-file)\n              (goto-char (point-min))\n              (while (re-search-forward \"^\\\\([^ ]+\\\\) +\\\\([0-9.]+\\\\)\" nil t)\n                (let* ((name (match-string 1))\n                       (baseline (string-to-number (match-string 2)))\n                       (actual (cdr (assoc name results))))\n                  (when (and actual (> actual (* baseline 1.05)))\n                    (message \"REGRESSION %s: %.6f > %.6f (baseline * 1.05)\"\n                             name actual (* baseline 1.05))\n                    (setq failed t))))))\n          (when failed (kill-emacs 1)))'\n",
